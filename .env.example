# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# OANDA (Forex)
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here
OANDA_ENVIRONMENT=practice  # practice or live

# TradingView (for chart login)
TV_USERNAME=your_tv_username_here
TV_PASSWORD=your_tv_password_here

# Crypto Fallback: CCXT (e.g., Binance)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# Database Security
DB_ENCRYPTION_KEY=your_32_byte_fernet_key_here  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Notifications: Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Risk Override (do not change unless you know exactly what you're doing)
OVERRIDE_DAILY_LOSS_LIMIT=false
EMERGENCY_HALT=false

# App Settings
LOG_LEVEL=INFO
ENVIRONMENT=development
